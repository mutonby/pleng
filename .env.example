# === Required ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Claude Code Auth (pick one) ===
# Option A: OAuth (default) — mount ~/.claude and ~/.claude.json via docker-compose
CLAUDE_AUTH_MODE=oauth
# Option B: API key
# CLAUDE_AUTH_MODE=api_key
# ANTHROPIC_API_KEY=sk-ant-...

# === Server ===
PUBLIC_IP=           # Your VPS public IP (curl ifconfig.me)
BASE_DOMAIN=         # Optional: custom domain for panel
ACME_EMAIL=admin@example.com

# === Optional ===
MODEL_NAME=claude-sonnet-4-20250514
WEB_UI_PASSWORD=admin
GITHUB_TOKEN=
GITHUB_ORG=
